---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
---
<BaseLayout title="Estrelis.ai — AI-Powered Medical Equipment Planning Software" description="Estrelis.ai is the first AI-native medical equipment planning platform for healthcare construction. Automate catalog management, Revit sync, budgeting, procurement, and field inventory across your projects.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="badge">&#x2728; THE FIRST AI-NATIVE MEQ PLATFORM</div>
      <h1>Medical Equipment Planning<br /><span class="gradient">Reimagined with AI</span></h1>
      <p>From room-by-room equipment lists to procurement and installation — Estrelis brings intelligent automation to every step of healthcare facility planning.</p>
      <div class="hero-buttons">
        <a href="/contact" class="btn-primary btn-lg">Request a Demo</a>
        <a href="/product" class="btn-secondary btn-lg">See How It Works &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features">
    <h2>Built for the way you actually work</h2>
    <p>AI that understands medical equipment, not just spreadsheets.</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon icon-cyan">&#x1F9E0;</div>
        <h3>AI Catalog Management</h3>
        <p>Intelligent catalog that matches specs automatically, flags discontinued items, and creates new entries — keeping the equipment library current without the manual grind.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon icon-blue">&#x1F3D7;</div>
        <h3>Revit Integration</h3>
        <p>Sync equipment plans directly with your BIM models. Room-level coordination between design and planning teams.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon icon-purple">&#x1F4CA;</div>
        <h3>Live Budget Tracking</h3>
        <p>Real-time budget visibility across departments, buildings, and project phases. No more spreadsheet reconciliation.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon icon-cyan">&#x1F517;</div>
        <h3>Procurement Workflow</h3>
        <p>From RFQs to purchase orders — manage vendor coordination, quotes, and approvals in one place.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon icon-blue">&#x1F465;</div>
        <h3>Client Portal</h3>
        <p>Give project stakeholders secure access to review equipment plans, approve budgets, and track project status.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon icon-purple">&#x1F4F1;</div>
        <h3>Field Inventory</h3>
        <p>Capture existing equipment with iPad — 360° photos, barcode scanning, and AI-powered asset identification.</p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="stats-grid">
      <div>
        <div class="stat-value">295K+</div>
        <div class="stat-label">Equipment Items Managed</div>
      </div>
      <div>
        <div class="stat-value">218</div>
        <div class="stat-label">Healthcare Projects</div>
      </div>
      <div>
        <div class="stat-value">85%</div>
        <div class="stat-label">AI Match Accuracy</div>
      </div>
      <div>
        <div class="stat-value">10x</div>
        <div class="stat-label">Faster Than Spreadsheets</div>
      </div>
    </div>
  </section>

  <!-- EXPLORE -->
  <section class="explore">
    <h2>Explore by Use Case</h2>
    <p>See how Estrelis fits your workflow.</p>
    <div class="explore-grid">
      <a href="/use-cases/new-construction/" class="explore-card">
        <h3>New Construction &#x2192;</h3>
        <p>Equipment planning for greenfield healthcare facilities — from design through move-in.</p>
      </a>
      <a href="/use-cases/renovation/" class="explore-card">
        <h3>Renovation &#x2192;</h3>
        <p>Inventory existing assets, plan reuse vs. replacement, and coordinate phased moves.</p>
      </a>
      <a href="/use-cases/field-inventory/" class="explore-card">
        <h3>Field Inventory &#x2192;</h3>
        <p>iPad-powered equipment capture with 360° photos and AI asset identification.</p>
      </a>
      <a href="/compare/spreadsheets/" class="explore-card">
        <h3>Estrelis vs. Spreadsheets &#x2192;</h3>
        <p>Why healthcare teams switch from Excel to purpose-built planning software.</p>
      </a>
      <a href="/integrations/revit/" class="explore-card">
        <h3>Revit Integration &#x2192;</h3>
        <p>Two-way BIM synchronization between Revit models and equipment plans.</p>
      </a>
      <a href="/faq/" class="explore-card">
        <h3>FAQ &#x2192;</h3>
        <p>Common questions about medical equipment planning and Estrelis.</p>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <h2>Ready to modernize your equipment planning?</h2>
    <p>See how Estrelis can transform your next healthcare project.</p>
    <a href="/contact" class="btn-primary btn-lg">Request a Demo</a>
  </section>

</BaseLayout>
