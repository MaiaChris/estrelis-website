---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/product.css';
---
<BaseLayout title="Medical Equipment Planning Software Features | Estrelis.ai" description="Explore Estrelis.ai features: AI-powered catalog management, Revit BIM integration, real-time budget tracking, procurement workflows, client portal, and iPad field inventory for healthcare projects.">

  <!-- HERO -->
  <section class="product-hero">
    <h1>The AI-Native Equipment Planning Platform</h1>
    <p>Purpose-built for healthcare — every feature designed to replace manual processes with intelligent automation.</p>
  </section>

  <!-- FEATURE DETAILS -->
  <div class="feature-details">

    <section class="feature-detail catalog-hero-section">
      <div class="feature-detail-content">
        <span class="feature-label">Core Intelligence</span>
        <h2>AI-Powered Equipment Catalog</h2>
        <p>Our catalog is the foundation of every project. Estrelis treats it that way — with AI woven into every operation. From matching incoming specs to flagging end-of-life products to building new entries from scratch, our catalog stays accurate, current, and ready for the next project without the manual overhead.</p>
      </div>
    </section>

    <div class="catalog-subsections">
      <div class="catalog-card">
        <span class="feature-label">Matching</span>
        <h3>Intelligent Spec Matching</h3>
        <p>Import equipment lists from any source — asset management systems, client spreadsheets, vendor submittals — and AI matches them to our catalog instantly. Every suggestion comes with a confidence score so you review decisions, not data entry.</p>
        <ul class="feature-bullets">
          <li>Confidence scoring on every match</li>
          <li>Batch processing for bulk imports</li>
          <li>Learns from your corrections over time</li>
          <li>Handles manufacturer aliases and model variants</li>
        </ul>
      </div>

      <div class="catalog-card">
        <span class="feature-label">Lifecycle</span>
        <h3>Discontinued Item Detection</h3>
        <p>Equipment gets discontinued mid-project all the time. Estrelis monitors our catalog and flags items that are end-of-life, out of production, or replaced by newer models — before they end up on a purchase order.</p>
        <ul class="feature-bullets">
          <li>Automatic end-of-life flagging</li>
          <li>Replacement product suggestions</li>
          <li>Impact analysis across active projects</li>
          <li>Vendor notification workflows</li>
        </ul>
      </div>

      <div class="catalog-card">
        <span class="feature-label">Creation</span>
        <h3>AI Catalog Item Generation</h3>
        <p>When there's no match, Estrelis doesn't leave you with a blank form. AI extracts manufacturer, model, specs, and category from vendor data and generates a new catalog entry — ready for your review and approval.</p>
        <ul class="feature-bullets">
          <li>Auto-extract specs from vendor submittals</li>
          <li>Pre-populated fields with AI confidence indicators</li>
          <li>Category and department classification</li>
          <li>Duplicate detection before creation</li>
        </ul>
      </div>
    </div>

    <section class="feature-detail">
      <div class="feature-detail-content">
        <span class="feature-label">BIM Connected</span>
        <h2>Seamless Revit Synchronization</h2>
        <p>Keep equipment plans synchronized with architectural models. Room-level coordination between design and planning teams, updated in real time.</p>
        <ul class="feature-bullets">
          <li>Two-way Revit sync via desktop plugin</li>
          <li>Room and level hierarchy from BIM</li>
          <li>Equipment placement validation</li>
          <li>Supports Revit 2024-2026</li>
        </ul>
      </div>
    </section>

    <section class="feature-detail">
      <div class="feature-detail-content">
        <span class="feature-label">Financial Visibility</span>
        <h2>Real-Time Budget Intelligence</h2>
        <p>See your equipment budget across every department, building, and project phase. No more spreadsheet reconciliation at month-end.</p>
        <ul class="feature-bullets">
          <li>Department and building rollups</li>
          <li>Point-in-time snapshots and phase-over-phase comparison</li>
          <li>Variance alerts and trend analysis</li>
          <li>Export to Excel with one click</li>
        </ul>
      </div>
    </section>

    <section class="feature-detail">
      <div class="feature-detail-content">
        <span class="feature-label">End-to-End</span>
        <h2>From RFQ to Purchase Order</h2>
        <p>Manage the entire procurement lifecycle. Send quote requests, track vendor responses, compare pricing, and generate purchase orders — all from one platform.</p>
        <ul class="feature-bullets">
          <li>Automated RFQ generation</li>
          <li>Vendor quote comparison</li>
          <li>Approval workflows</li>
          <li>Purchase order generation with ERP integration</li>
        </ul>
      </div>
    </section>

    <section class="feature-detail">
      <div class="feature-detail-content">
        <span class="feature-label">Client-Facing</span>
        <h2>Transparent Client Collaboration</h2>
        <p>Give healthcare clients secure, passwordless access to their project. They can review equipment plans, approve budgets, and track status without needing training.</p>
        <ul class="feature-bullets">
          <li>Magic link authentication (no passwords)</li>
          <li>Equipment list review and approval</li>
          <li>Budget visibility by department</li>
          <li>Real-time project status</li>
        </ul>
      </div>
    </section>

    <section class="feature-detail">
      <div class="feature-detail-content">
        <span class="feature-label">Mobile</span>
        <h2>iPad-Powered Field Capture</h2>
        <p>Walk through existing facilities and capture equipment data with an iPad. 360-degree panoramic photos, barcode scanning, and AI-powered asset identification.</p>
        <ul class="feature-bullets">
          <li>360° panoramic room capture</li>
          <li>Barcode and label scanning</li>
          <li>AI asset identification</li>
          <li>Offline-capable for hospital environments</li>
        </ul>
      </div>
    </section>

  </div>

  <!-- CTA -->
  <section class="cta">
    <h2>See it in action</h2>
    <p>Schedule a personalized demo with our team.</p>
    <a href="/contact" class="btn-primary btn-lg">Request a Demo</a>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Estrelis.ai",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "AI-powered medical equipment planning software for healthcare construction and renovation projects. Features include AI catalog management, Revit BIM integration, real-time budget tracking, procurement workflows, client portal, and iPad field inventory.",
    "url": "https://www.estrelis.ai/product/",
    "offers": {
      "@type": "Offer",
      "category": "SaaS"
    },
    "publisher": {
      "@id": "https://www.estrelis.ai/#organization"
    },
    "featureList": [
      "AI-powered equipment catalog with 295,000+ items",
      "Intelligent spec matching with confidence scores",
      "Discontinued item detection",
      "AI catalog item generation",
      "Two-way Revit BIM synchronization",
      "Real-time budget tracking by department, building, phase",
      "RFQ generation and vendor quote comparison",
      "Passwordless client portal with magic link access",
      "iPad field inventory with 360° panoramic photos",
      "Barcode scanning and AI asset identification"
    ]
  })} />

</BaseLayout>
