    </div>
  </nav>

  <section class="cta">
    <h2>Planning a new healthcare facility?</h2>
    <p>See how Estrelis can streamline your equipment planning process.</p>
    <a href="/contact" class="btn-primary btn-lg">Request a Demo</a>
  </section>

</BaseLayout>
